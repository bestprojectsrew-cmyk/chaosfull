# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── LLM (Groq primary, Gemini + OpenRouter as automatic fallback) ─────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here   # optional

# ── Web Search (Tavily primary, Serper as backup) ──────────────────────────────
# Tavily — built for AI agents, 1000 free credits/month, very reliable
#   Get key: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Serper — backup only, used if Tavily fails or isn't set
#   Get key: https://serper.dev
SERPER_KEY=your_serper_key_here

# ── PostgreSQL (Railway) ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# ── App ─────────────────────────────────────────────────────────────────────────
WEBHOOK_URL=https://your-railway-app.up.railway.app
PORT=8000
